{
  "name": "playwright-demo-js",
  "version": "1.0.0",
  "description": "Playwright demo with JavaScript",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:sauce": "saucectl run",
    "show-report": "npx playwright show-report",
    "test:smoke": "npx playwright test --grep @smoke --project=chrome",
    "test:chrome": "npx playwright test --project=chromium",
    "allure:clean": "rm -rf allure-results",
    "allure-generate": "allure generate ./allure-results --clean",
    "allure:report": "npm run allure-generate && allure serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://jay-yeluru@github.com/jay-yeluru/playwright-demo-js.git"
  },
  "keywords": [
    "Playwright",
    "JavaScript"
  ],
  "author": "Jay Yeluru",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jay-yeluru/playwright-demo-js/issues"
  },
  "homepage": "https://github.com/jay-yeluru/playwright-demo-js#readme",
  "dependencies": {
    "allure-playwright": "^3.4.5",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "allure-playwright": "^3.4.5",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.8.1",
    "saucectl": "^0.175.0"
  }
}
