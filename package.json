    "type": "git",
    "url": "git+https://github.com/jay-yeluru/playwright-demo-js.git"
  },
  "bugs": {
    "url": "https://github.com/jay-yeluru/playwright-demo-js/issues"
  },
  "homepage": "https://github.com/jay-yeluru/playwright-demo-js#readme",
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "allure-playwright": "^3.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
