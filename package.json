{
  "name": "playwright-demo-js",
  "version": "1.0.0",
  "description": "Playwright demo with JavaScript",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:chrome": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:safari": "npx playwright test --project=webkit",
    "test:edge": "npx playwright test --project=edge",
    "test:smoke": "npx playwright test --grep @smoke",
    "show-report": "npx playwright show-report reports"
  },
  "keywords": [
    "Playwright",
    "JavaScript"
  ],
